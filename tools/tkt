#!/usr/bin/env bash
# tkt — minimal ticket system bundled with canon
# Tickets are stored in .tickets/<id>/ticket.md. Legacy .tickets/<id>.md
# files remain readable.

set -euo pipefail

VERSION="1.0.0"

# Walk up directory tree to find .tickets/, fallback to $PWD/.tickets
tickets_dir() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -d "$dir/.tickets" ]] && echo "$dir/.tickets" && return 0
    [[ -d "$dir/.git" ]] && echo "$dir/.tickets" && return 0
    dir="$(dirname "$dir")"
  done
  echo "$PWD/.tickets"
}

active_file() {
  local dir
  dir="$(ensure_tickets_dir)"
  echo "$dir/ACTIVE"
}

ensure_tickets_dir() {
  local dir
  dir="$(tickets_dir)"
  mkdir -p "$dir"
  echo "$dir"
}

gen_id() {
  local suffix
  suffix=$(LC_ALL=C tr -dc 'a-z0-9' < /dev/urandom | head -c 4)
  echo "t-$suffix"
}

ticket_files() {
  local dir="$1"
  {
    find "$dir" -mindepth 2 -maxdepth 2 -name "ticket.md" -type f 2>/dev/null
    find "$dir" -maxdepth 1 -name "*.md" -type f 2>/dev/null \
      ! -name "*-blueprint.md" \
      ! -name "*-acceptance.md" \
      ! -name "*-plan.md" \
      ! -name "*-decisions.md" \
      ! -name "*-qa.md" \
      ! -name "*-notes.md"
  } | sort
}

# Find ticket file by partial or full ID match
find_ticket() {
  local query="$1"
  local dir
  dir="$(tickets_dir)"
  [[ ! -d "$dir" ]] && { echo "Error: no .tickets directory found" >&2; exit 1; }

  local matches=()
  while IFS= read -r file; do
    local file_id
    file_id="$(get_field "$file" id)"
    [[ "$file_id" == *"$query"* ]] && matches+=("$file")
  done < <(ticket_files "$dir")

  case ${#matches[@]} in
    0) echo "Error: no ticket matching '$query'" >&2; exit 1 ;;
    1) echo "${matches[0]}" ;;
    *) echo "Error: ambiguous ID '$query' — ${#matches[@]} matches" >&2; exit 1 ;;
  esac
}

get_field() {
  local file="$1" field="$2"
  awk -v f="$field" '
    /^---$/ { fm++; next }
    fm == 1 && match($0, "^" f ": ") { print substr($0, RSTART+RLENGTH); exit }
  ' "$file"
}

set_field() {
  local file="$1" field="$2" value="$3"
  awk -v f="$field" -v v="$value" '
    /^---$/ { fm++; print; next }
    fm == 1 && match($0, "^" f ": ") { print f ": " v; next }
    { print }
  ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
}

get_title() {
  local title
  title="$(awk '/^---$/{fm++} fm==2 && /^# /{sub(/^# /,""); print; exit}' "$1")"
  if [[ -n "$title" ]]; then
    echo "$title"
  else
    title="$(get_field "$1" title)"
    if [[ -n "$title" ]]; then
      echo "$title"
    elif [[ "$(basename "$1")" == "ticket.md" ]]; then
      basename "$(dirname "$1")"
    else
      basename "$1" .md
    fi
  fi
}

set_active() {
  local id="$1" file
  file="$(active_file)"
  printf "%s\n" "$id" > "$file"
}

clear_active_if() {
  local id="$1" file current
  file="$(active_file)"
  [[ -f "$file" ]] || return 0
  current="$(tr -d '[:space:]' < "$file")"
  [[ "$current" == "$id" ]] && rm -f "$file"
}

current_id() {
  local dir file id matches=()
  dir="$(tickets_dir)"
  file="$dir/ACTIVE"
  if [[ -f "$file" ]]; then
    id="$(tr -d '[:space:]' < "$file")"
    if [[ -n "$id" ]] && find_ticket "$id" >/dev/null 2>&1; then
      echo "$id"
      return 0
    fi
  fi

  [[ -d "$dir" ]] || return 1
  while IFS= read -r file; do
    [[ "$(get_field "$file" status)" == "in_progress" ]] || continue
    matches+=("$(get_field "$file" id)")
  done < <(ticket_files "$dir")

  case ${#matches[@]} in
    1) echo "${matches[0]}" ;;
    0) return 1 ;;
    *) echo "Error: multiple in-progress tickets; run 'tkt start <id>' to set ACTIVE" >&2; return 2 ;;
  esac
}

cmd_create() {
  local title="" type="task" priority="2" description=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -t|--type)        type="$2";        shift 2 ;;
      -p|--priority)    priority="$2";    shift 2 ;;
      -d|--description) description="$2"; shift 2 ;;
      -*) echo "Unknown option: $1" >&2; exit 1 ;;
      *)  [[ -z "$title" ]] && title="$1"; shift ;;
    esac
  done

  [[ -z "$title" ]] && { echo "Error: title required" >&2; exit 1; }

  local dir id ticket_dir file created
  dir="$(ensure_tickets_dir)"

  while true; do
    id="$(gen_id)"
    ticket_dir="$dir/$id"
    file="$ticket_dir/ticket.md"
    [[ ! -e "$ticket_dir" && ! -f "$dir/$id.md" ]] && break
  done

  mkdir -p "$ticket_dir"
  created="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  {
    printf -- "---\n"
    printf "id: %s\n" "$id"
    printf "status: open\n"
    printf "created: %s\n" "$created"
    printf "type: %s\n" "$type"
    printf "priority: %s\n" "$priority"
    printf -- "---\n"
    printf "# %s\n" "$title"
    [[ -n "$description" ]] && printf "\n%s\n" "$description"
  } > "$file"

  echo "$id"
}

cmd_set_status() {
  local id="${1:-}" new_status="$2"
  [[ -z "$id" ]] && { echo "Error: ticket ID required" >&2; exit 1; }
  local file
  file="$(find_ticket "$id")"
  set_field "$file" status "$new_status"
  id="$(get_field "$file" id)"
  if [[ "$new_status" == "in_progress" ]]; then
    set_active "$id"
  elif [[ "$new_status" == "closed" ]]; then
    clear_active_if "$id"
  fi
  printf "%s: %s\n" "$id" "$new_status"
}

cmd_ls() {
  local status_filter=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status=*) status_filter="${1#--status=}"; shift ;;
      --status)   status_filter="$2"; shift 2 ;;
      *)          shift ;;
    esac
  done

  local dir
  dir="$(tickets_dir)"
  [[ ! -d "$dir" ]] && { echo "No tickets found."; return; }

  local found=0
  while IFS= read -r file; do
    local id status type priority title
    id="$(get_field "$file" id)"
    status="$(get_field "$file" status)"
    [[ -n "$status_filter" && "$status" != "$status_filter" ]] && continue
    type="$(get_field "$file" type)"
    priority="$(get_field "$file" priority)"
    title="$(get_title "$file")"
    printf "%-10s  %-12s  %-8s  p%s  %s\n" "$id" "$status" "$type" "$priority" "$title"
    (( found++ )) || true
  done < <(ticket_files "$dir")

  if [[ $found -eq 0 ]]; then
    echo "No tickets${status_filter:+ with status '$status_filter'}."
  fi
}

cmd_show() {
  [[ $# -eq 0 ]] && { echo "Usage: tkt show <id>" >&2; exit 1; }
  local file
  file="$(find_ticket "$1")"

  printf "ID:       %s\n" "$(get_field "$file" id)"
  printf "Status:   %s\n" "$(get_field "$file" status)"
  printf "Type:     %s\n" "$(get_field "$file" type)"
  printf "Priority: %s\n" "$(get_field "$file" priority)"
  printf "Created:  %s\n" "$(get_field "$file" created)"
  printf "Title:    %s\n" "$(get_title "$file")"

  local body
  body="$(awk '/^---$/{fm++; next} fm>=2 && !/^# /{print}' "$file")"
  if [[ -n "$body" ]]; then
    printf "\n%s\n" "$body"
  fi
}

cmd_current() {
  local id rc file
  set +e
  id="$(current_id)"
  rc=$?
  set -e
  if [[ "$rc" -eq 1 ]]; then
    echo "No active ticket."
    return 1
  elif [[ "$rc" -ne 0 ]]; then
    return "$rc"
  fi
  file="$(find_ticket "$id")"
  printf "%s  %s  %s\n" "$id" "$(get_field "$file" status)" "$(get_title "$file")"
}

cmd_help() {
  cat <<'EOF'
tkt — minimal ticket system

Usage: tkt <command> [args]

Commands:
  create [title] [options]  Create ticket, prints ID
    -d, --description       Description text
    -t, --type              Type (bug|feature|task|epic|chore) [default: task]
    -p, --priority          Priority 0-4, 0=highest [default: 2]
  start <id>                Set status to in_progress and mark ACTIVE
  close <id>                Set status to closed and clear ACTIVE if matched
  current                   Show active ticket
  reopen <id>               Set status to open
  ls [--status=X]           List tickets (unfiltered by default)
  show <id>                 Display ticket details

New tickets are stored in .tickets/<id>/ticket.md
ACTIVE ticket is stored in .tickets/ACTIVE
Supports partial ID matching (e.g., 'tkt show 8ms' matches 't-8ms5')
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    create)         cmd_create "$@" ;;
    start)          cmd_set_status "${1:-}" in_progress ;;
    close)          cmd_set_status "${1:-}" closed ;;
    current)        cmd_current ;;
    reopen)         cmd_set_status "${1:-}" open ;;
    ls|list)        cmd_ls "$@" ;;
    show)           cmd_show "$@" ;;
    help|--help|-h) cmd_help ;;
    --version|-v)   echo "tkt $VERSION" ;;
    *)              echo "Unknown command: $cmd" >&2; cmd_help; exit 1 ;;
  esac
}

main "$@"
