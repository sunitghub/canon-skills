#!/usr/bin/env bash
# sprint-check-win — run the Go sprint-check server from the source tree

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if ! command -v go >/dev/null 2>&1; then
  echo "Error: Go is required to run sprint-check-win from source." >&2
  exit 1
fi

cd "$ROOT"
exec env GO111MODULE=off go run ./tools/sprint-check-go "$@"
