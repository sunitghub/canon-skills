#!/usr/bin/env bash
# sprint — CLI-backed orchestration spine for canon workflows

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TKT_BIN="$SCRIPT_DIR/tkt"

tickets_dir() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -d "$dir/.tickets" ]] && echo "$dir/.tickets" && return 0
    [[ -d "$dir/.git" ]] && echo "$dir/.tickets" && return 0
    dir="$(dirname "$dir")"
  done
  echo "$PWD/.tickets"
}

project_root() {
  dirname "$(tickets_dir)"
}

ticket_dir_for() {
  local id="$1"
  echo "$(tickets_dir)/$id"
}

ensure_context_files() {
  local root="$1"
  if [[ ! -f "$root/DECISIONS.md" ]]; then
    cat > "$root/DECISIONS.md" <<'EOF'
# Decisions

| Date | Decision | Reason |
|---|---|---|
EOF
  fi

  if [[ ! -f "$root/HANDOFF.md" ]]; then
    cat > "$root/HANDOFF.md" <<'EOF'
# Handoff

## Current Focus

## In Progress

## Recent Decisions

## Discoveries

## Next Steps
1.
EOF
  fi
}

write_if_missing() {
  local file="$1" content="$2"
  [[ -f "$file" ]] && return 0
  printf "%s\n" "$content" > "$file"
}

cmd_start() {
  local title="${1:-}"
  [[ -z "$title" ]] && { echo "Usage: sprint start \"title\"" >&2; exit 1; }

  local current_output current_rc
  set +e
  current_output="$("$TKT_BIN" current 2>&1)"
  current_rc=$?
  set -e
  if [[ "$current_rc" -eq 0 ]]; then
    echo "Active sprint already exists:"
    echo "$current_output"
    echo "Run 'sprint complete' or close/reopen tickets before starting another."
    exit 1
  elif [[ "$current_rc" -gt 1 ]]; then
    echo "$current_output" >&2
    exit "$current_rc"
  fi

  local root dir id tdir
  root="$(project_root)"
  dir="$(tickets_dir)"
  mkdir -p "$dir"

  id="$("$TKT_BIN" create "$title" -t task -p 2)"
  "$TKT_BIN" start "$id" >/dev/null
  tdir="$(ticket_dir_for "$id")"
  mkdir -p "$tdir"

  ensure_context_files "$root"

  cat <<EOF
Sprint started: $id
Ticket: $tdir/ticket.md

Agent next steps:
1. Read DECISIONS.md, HANDOFF.md, and ticket.md.
2. Create acceptance.md with done criteria, test plan, and QA sign-off.
3. Create plan.md with the approach and decisions after explicit approval.
EOF
}

cmd_current() {
  "$TKT_BIN" current
}

cmd_status() {
  local id tdir
  local current_out current_rc
  set +e; current_out="$("$TKT_BIN" current 2>&1)"; current_rc=$?; set -e
  if [[ "$current_rc" -gt 1 ]]; then echo "$current_out" >&2; exit "$current_rc"; fi
  if [[ "$current_rc" -ne 0 ]]; then echo "No active sprint."; exit 1; fi
  id="$(awk '{print $1}' <<< "$current_out")"
  tdir="$(ticket_dir_for "$id")"
  "$TKT_BIN" show "$id"
  echo ""
  echo "Sprint files:"
  for f in ticket.md acceptance.md plan.md; do
    if [[ -f "$tdir/$f" ]]; then
      echo "  [ok]      $tdir/$f"
    else
      echo "  [missing] $tdir/$f"
    fi
  done
}

cmd_complete() {
  local id tdir acceptance missing=0 unchecked=0
  local current_out current_rc
  set +e; current_out="$("$TKT_BIN" current 2>&1)"; current_rc=$?; set -e
  if [[ "$current_rc" -gt 1 ]]; then echo "$current_out" >&2; exit "$current_rc"; fi
  if [[ "$current_rc" -ne 0 ]]; then echo "No active sprint."; exit 1; fi
  id="$(awk '{print $1}' <<< "$current_out")"

  tdir="$(ticket_dir_for "$id")"
  acceptance="$tdir/acceptance.md"

  for f in "$tdir/ticket.md" "$acceptance" "$tdir/plan.md"; do
    if [[ ! -f "$f" ]]; then
      echo "Missing required sprint file: $f"
      missing=1
    fi
  done
  [[ "$missing" -eq 0 ]] || exit 1

  if grep -q '^- \[ \]' "$acceptance"; then
    unchecked=1
  fi

  if [[ "$unchecked" -eq 1 ]]; then
    echo "Sprint $id is not complete. Unchecked acceptance/test items remain:"
    grep '^- \[ \]' "$acceptance" || true
    exit 1
  fi

  "$TKT_BIN" close "$id"
  echo "Sprint completed: $id"
}

cmd_help() {
  cat <<'EOF'
sprint — canon workflow spine

Usage:
  sprint start "title"   Create/start ticket and context files
  sprint current         Show the active sprint ticket
  sprint status          Show active ticket and required sprint files
  sprint complete        Validate acceptance checklist and close ticket

The CLI owns deterministic workflow state. The agent still owns orientation,
gray-area resolution, impact analysis, implementation, review, and test judgment.
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    start) cmd_start "$@" ;;
    current) cmd_current ;;
    status) cmd_status ;;
    complete) cmd_complete ;;
    help|--help|-h) cmd_help ;;
    *) echo "Unknown command: $cmd" >&2; cmd_help; exit 1 ;;
  esac
}

main "$@"
