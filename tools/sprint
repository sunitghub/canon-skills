#!/usr/bin/env bash
# sprint — CLI-backed orchestration spine for canon workflows

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/ticket-root.sh"
TKT_BIN="$SCRIPT_DIR/tkt"

ticket_dir_for() {
  local id="$1"
  echo "$(tickets_dir)/$id"
}

ensure_context_files() {
  local root="$1"
  if [[ ! -f "$root/DECISIONS.md" ]]; then
    cat > "$root/DECISIONS.md" <<'EOF'
# Decisions

| Date | Decision | Reason |
|---|---|---|
EOF
  fi

  if [[ ! -f "$root/HANDOFF.md" ]]; then
    cat > "$root/HANDOFF.md" <<'EOF'
# Handoff

## Current Focus

## In Progress

## Discoveries

## Next Steps
1.
EOF
  fi
}

write_if_missing() {
  local file="$1" content="$2"
  [[ -f "$file" ]] && return 0
  printf "%s\n" "$content" > "$file"
}

cmd_start() {
  local arg="${1:-}"
  [[ -z "$arg" ]] && { echo "Usage: sprint start \"title\" | sprint start <ticket-id>" >&2; exit 1; }

  local current_output current_rc
  set +e
  current_output="$("$TKT_BIN" current 2>&1)"
  current_rc=$?
  set -e
  if [[ "$current_rc" -eq 0 ]]; then
    echo "Active sprint already exists:"
    echo "$current_output"
    echo "Run 'sprint complete' or close/reopen tickets before starting another."
    exit 1
  elif [[ "$current_rc" -gt 1 ]]; then
    echo "$current_output" >&2
    exit "$current_rc"
  fi

  local root dir id tdir
  root="$(project_root)"
  dir="$(tickets_dir)"
  mkdir -p "$dir"

  # Resolve arg as an existing ticket ID; fall back to creating a new ticket.
  local resolved_id
  resolved_id="$("$TKT_BIN" show "$arg" 2>/dev/null | awk '/^ID:/{print $2}' || true)"
  if [[ -n "$resolved_id" ]]; then
    id="$resolved_id"
  else
    id="$("$TKT_BIN" create "$arg" -t task -p 2)"
  fi
  "$TKT_BIN" start "$id" >/dev/null
  tdir="$(ticket_dir_for "$id")"
  mkdir -p "$tdir"

  [[ -f "$tdir/acceptance.md" ]] || cat > "$tdir/acceptance.md" <<EOF
# Acceptance

<!-- Keep the Ticket line below unchanged. -->
Ticket: \`$id\`

## Criteria
The checklist of behavior that must be true before the sprint can close.
<!-- Add or edit checklist items below. Keep this heading unchanged. -->

- [ ]

## Test Plan
The commands or checks that prove the criteria work.
<!-- Add or edit test commands below. Keep this heading unchanged. -->

- [ ]

## QA
Edge cases and sign-off.
<!-- Add or edit QA items below. Keep this heading unchanged. -->

- [ ] Tested locally
EOF

  [[ -f "$tdir/plan.md" ]] || cat > "$tdir/plan.md" <<EOF
# Plan

<!-- Keep the Ticket line below unchanged. -->
Ticket: \`$id\`
<!-- Keep this doc under ~500 words — it is injected at every session start. -->

## Sign-off
<!-- Fill in: Tier: <tier> | Risk: <blast radius / key risks, one line> -->

- [ ] Plan approved — proceed to implementation

## Approach
<!-- Describe how you will implement this. Keep this heading unchanged. -->

## Files
<!-- List files to create or modify. -->

## Decisions
<!-- Record non-obvious tradeoffs and why. Keep this heading unchanged. -->
EOF

  ensure_context_files "$root"

  if [[ ! -x "$root/scripts/test.sh" ]]; then
    echo "[sprint] WARNING: no scripts/test.sh found — test gate will not run at commit."
  fi

  cat <<EOF
Sprint started: $id
Ticket: $tdir/ticket.md

Agent next steps:
1. Read DECISIONS.md, HANDOFF.md, and ticket.md.
2. Fill in acceptance.md — add criteria and test-plan checklist items.
3. Fill in plan.md — write the approach, then wait for explicit approval before coding.
EOF
}

cmd_current() {
  "$TKT_BIN" current
}

cmd_status() {
  local id tdir
  local current_out current_rc
  set +e; current_out="$("$TKT_BIN" current 2>&1)"; current_rc=$?; set -e
  if [[ "$current_rc" -gt 1 ]]; then echo "$current_out" >&2; exit "$current_rc"; fi
  if [[ "$current_rc" -ne 0 ]]; then echo "No active sprint."; exit 1; fi
  id="$(awk '{print $1}' <<< "$current_out")"
  tdir="$(ticket_dir_for "$id")"
  "$TKT_BIN" show "$id"
  echo ""
  echo "Sprint files:"
  for f in ticket.md acceptance.md plan.md; do
    if [[ -f "$tdir/$f" ]]; then
      echo "  [ok]      $tdir/$f"
    else
      echo "  [missing] $tdir/$f"
    fi
  done
}

_acceptance_section() {
  awk -v h="$1" '$0 ~ "^##[[:space:]]+"h"[[:space:]]*$" { f=1; next } /^##[[:space:]]/ { f=0 } f' "$2"
}

_gate_sprint_files() {
  local id="$1" tdir="$2" acceptance="$3" missing=0
  for f in "$tdir/ticket.md" "$acceptance" "$tdir/plan.md" "$tdir/summary.md"; do
    [[ ! -f "$f" ]] && echo "Missing required sprint file: $f" && missing=1
  done
  return $missing
}

_gate_acceptance_sections() {
  local id="$1" acceptance="$2" missing=0
  if ! _acceptance_section "Criteria" "$acceptance" | grep -qE '^[[:space:]]*[-*] \[[ xX]\][[:space:]]+\S'; then
    echo "Sprint $id cannot close: acceptance.md ## Criteria has no checklist items."
    echo "Add done criteria to acceptance.md, then re-run."
    missing=1
  fi
  if ! _acceptance_section "Test Plan" "$acceptance" | grep -qE '^[[:space:]]*[-*] \[[ xX]\][[:space:]]+\S'; then
    echo "Sprint $id cannot close: acceptance.md ## Test Plan has no checklist items."
    echo "Add test commands to acceptance.md, then re-run."
    missing=1
  fi
  return $missing
}

_gate_wrapup_gates() {
  local id="$1" acceptance="$2"
  if ! grep -q "^## Wrapup Gates" "$acceptance"; then
    echo "Sprint $id cannot close: acceptance.md is missing ## Wrapup Gates section."
    echo "Run wrapup before closing."
    return 1
  fi

  local section data_rows
  section="$(_acceptance_section "Wrapup Gates" "$acceptance")"
  data_rows="$(printf '%s\n' "$section" | grep -E '^\|[[:space:]]*[a-zA-Z]' | grep -ivE '^\|[[:space:]]*gate[[:space:]]*\|')"

  if [[ -z "$data_rows" ]]; then
    echo "Sprint $id cannot close: ## Wrapup Gates table has no data rows."
    echo "Fill in the wrapup gates table before closing."
    return 1
  fi

  if ! printf '%s\n' "$data_rows" | awk -F'|' '
    { r=$4; gsub(/^[[:space:]]+|[[:space:]]+$/, "", r)
      if (r == "" || r == "-" || r == "—") { exit 1 } }
  '; then
    echo "Sprint $id cannot close: ## Wrapup Gates has a row with empty or placeholder reason."
    echo "Add a reason for each gate before closing."
    return 1
  fi

  if ! printf '%s\n' "$data_rows" | grep -qE '^\|[^|]+\|[[:space:]]*ran[[:space:]]*\|'; then
    echo "Sprint $id cannot close: ## Wrapup Gates has no 'ran' rows — at least one gate must run."
    return 1
  fi
}

_gate_no_unchecked() {
  local id="$1" acceptance="$2"
  if grep -qE '^[[:space:]]*[-*] \[ \]' "$acceptance"; then
    echo "Sprint $id is not complete. Unchecked acceptance/test items remain:"
    grep -E '^[[:space:]]*[-*] \[ \]' "$acceptance" || true
    return 1
  fi
}

_gate_plan_signoff() {
  local id="$1" plan="$2"
  # Trivial-tier sprints skip the sign-off gate
  if grep -qiE 'tier[[:space:]]*:?[[:space:]]*\*{0,2}trivial' "$plan" 2>/dev/null; then
    return 0
  fi
  if ! grep -q "^## Sign-off" "$plan"; then
    echo "Sprint $id cannot close: plan.md is missing ## Sign-off section."
    echo "Add the Sign-off section and check the approval box before closing."
    return 1
  fi
  if _acceptance_section "Sign-off" "$plan" | grep -qE '^[[:space:]]*[-*] \[ \]'; then
    echo "Sprint $id cannot close: plan.md ## Sign-off has unchecked items."
    echo "Check the approval box in plan.md before closing."
    return 1
  fi
  if ! _acceptance_section "Sign-off" "$plan" | grep -qE '^[[:space:]]*[-*] \[[xX]\]'; then
    echo "Sprint $id cannot close: plan.md ## Sign-off has no checked approval."
    echo "Check the approval box in plan.md before closing."
    return 1
  fi
}

_gate_plan_content() {
  local id="$1" plan="$2"
  # Extract ## Approach section, strip HTML comments and blank lines
  local content
  content="$(_acceptance_section "Approach" "$plan" \
    | sed 's/<!--[^>]*-->//g' \
    | sed '/^[[:space:]]*$/d')"
  if [[ -z "$content" ]]; then
    echo "Sprint $id cannot close: plan.md ## Approach has no content."
    echo "Describe the implementation approach in plan.md, then re-run."
    return 1
  fi
}

_gate_eval_report() {
  local id="$1" tdir="$2"
  local plan="$tdir/plan.md" report="$tdir/eval-report.md"
  # Trivial-tier sprints skip the evaluator — check plan.md tier marker
  if grep -qiE 'tier[[:space:]]*:?[[:space:]]*\*{0,2}trivial' "$plan" 2>/dev/null; then
    return 0
  fi
  if [[ ! -f "$report" ]]; then
    echo "Sprint $id cannot close: eval-report.md is missing."
    echo "Run the evaluator (eval skill) before closing, or confirm trivial tier in plan.md."
    return 1
  fi
  if ! grep -qE '^evaluator-run-id:[[:space:]]+\S' "$report"; then
    echo "Sprint $id cannot close: eval-report.md is missing evaluator-run-id field."
    echo "Ensure the evaluator subagent wrote the run-id before grading."
    return 1
  fi
  local run_id run_epoch jsonl
  run_id="$(grep -E '^evaluator-run-id:[[:space:]]+\S' "$report" | head -1 | sed 's/^evaluator-run-id:[[:space:]]*//')"
  run_epoch="$(echo "$run_id" | cut -d'-' -f1)"
  jsonl="$(project_root)/.claude/subagent-runs.jsonl"
  if [[ -f "$jsonl" && "$run_epoch" =~ ^[0-9]+$ ]]; then
    local matched
    matched="$(python3 - "$jsonl" "$run_epoch" <<'PYEOF'
import sys, json, datetime
log_path, run_epoch = sys.argv[1], int(sys.argv[2])
matched = False
try:
    with open(log_path) as f:
        for line in f:
            line = line.strip()
            if not line: continue
            try:
                d = json.loads(line)
                ts = d.get('ts', '')
                if not ts: continue
                entry_epoch = int(datetime.datetime.strptime(ts, '%Y-%m-%dT%H:%M:%SZ').replace(tzinfo=datetime.timezone.utc).timestamp())
                if abs(entry_epoch - run_epoch) <= 3600:
                    matched = True
                    break
            except Exception:
                pass
except Exception:
    pass
print('1' if matched else '0')
PYEOF
)"
    if [[ "$matched" != "1" ]]; then
      echo "Sprint $id cannot close: evaluator-run-id '$run_id' has no matching subagent entry in .claude/subagent-runs.jsonl (±60 min window)."
      echo "The eval must be run as a real subagent invocation — inline writes are not accepted."
      return 1
    fi
  fi
  if ! grep -qE '^pass:' "$report"; then
    echo "Sprint $id cannot close: eval-report.md verdict is not pass."
    grep -E '^(pass|fail):' "$report" | head -1 || echo "(no verdict line found)"
    return 1
  fi
}

cmd_complete() {
  local id tdir acceptance
  local current_out current_rc
  set +e; current_out="$("$TKT_BIN" current 2>&1)"; current_rc=$?; set -e
  if [[ "$current_rc" -gt 1 ]]; then echo "$current_out" >&2; exit "$current_rc"; fi
  if [[ "$current_rc" -ne 0 ]]; then echo "No active sprint."; exit 1; fi
  id="$(awk '{print $1}' <<< "$current_out")"

  tdir="$(ticket_dir_for "$id")"
  acceptance="$tdir/acceptance.md"

  _gate_sprint_files        "$id" "$tdir" "$acceptance"  || exit 1
  _gate_acceptance_sections "$id" "$acceptance"          || exit 1
  _gate_wrapup_gates        "$id" "$acceptance"          || exit 1
  _gate_no_unchecked        "$id" "$acceptance"          || exit 1
  _gate_plan_content        "$id" "$tdir/plan.md"        || exit 1
  _gate_plan_signoff        "$id" "$tdir/plan.md"        || exit 1
  _gate_eval_report         "$id" "$tdir"                || exit 1

  "$TKT_BIN" close "$id"
  echo "Sprint completed: $id"
}

cmd_help() {
  cat <<'EOF'
sprint — canon workflow spine

Usage:
  sprint start "title"      Create a new ticket and start the sprint
  sprint start <ticket-id>  Start the sprint on an existing ticket (no new ticket created)
  sprint current            Show the active sprint ticket
  sprint status             Show active ticket and required sprint files
  sprint complete           Validate acceptance checklist and close ticket

The CLI owns deterministic workflow state. The agent still owns orientation,
gray-area resolution, impact analysis, implementation, review, and test judgment.
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    start) cmd_start "$@" ;;
    current) cmd_current ;;
    status) cmd_status ;;
    complete) cmd_complete ;;
    help|--help|-h) cmd_help ;;
    *) echo "Unknown command: $cmd" >&2; cmd_help; exit 1 ;;
  esac
}

main "$@"
