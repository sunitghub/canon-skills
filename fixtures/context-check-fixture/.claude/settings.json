{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "storybook": {
      "command": "npx",
      "args": ["-y", "@storybook/addon-docs-mcp@latest"]
    },
    "internal-data": {
      "command": "node",
      "args": ["./scripts/internal-data-mcp.js"],
      "env": {
        "DATAFLOW_API_TOKEN": "placeholder-token-do-not-use",
        "DATAFLOW_API_HOST": "https://example.invalid"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] bash tool used'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ./scripts/check-generated-context.js"
          }
        ]
      }
    ]
  }
}
